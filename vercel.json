{
    "builds":[
        {
            "src": "ThreadOra/wsgi.py",
            "user": "@vercel/python",
            "config": { "maxLambdaSize": "15mb", "runtime": "python3.11.3"}
        }
    ],
    "routes":[
        {
            "src": "/(.*)",
            "dest": "ThreadOra/wsgi.py"
        }
    ]
}